{
  "_comment": "FiniexDataCollector Configuration",
  "app_name": "FiniexDataCollector",
  "version": "1.0.0",
  "environment": "production",
  "paths": {
    "raw_data_dir": "./data/raw",
    "broker_configs_dir": "./configs/brokers",
    "logs_dir": "./logs"
  },
  "logging": {
    "console_level": "DEBUG",
    "file_level": "INFO"
  },
  "kraken": {
    "enabled": true,
    "broker_type": "kraken_spot",
    "server_name": "kraken_websocket",
    "websocket_url": "wss://ws.kraken.com/v2",
    "symbols": [
      "BTC/USD",
      "ETH/USD",
      "SOL/USD",
      "ADA/USD",
      "XRP/USD",
      "DASH/USD",
      "LTC/USD",
      "ETH/EUR"
    ],
    "streams": [
      "trade"
    ],
    "reconnect_max_delay_seconds": 60,
    "reconnect_initial_delay_seconds": 1,
    "heartbeat_interval_seconds": 30,
    "max_ticks_per_file": 50000
  },
  "mt5": {
    "enabled": false,
    "raw_data_path": ""
  },
  "telegram": {
    "enabled": false,
    "bot_token": "",
    "chat_id": "",
    "send_on_error": true,
    "send_on_rotation": false,
    "send_weekly_report": true
  },
  "scheduler": {
    "report_day": "saturday",
    "report_hour_utc": 6,
    "report_minute_utc": 0
  },
  "monitoring": {
    "disk_space_check_interval_seconds": 60,
    "folder_scan_interval_seconds": 60,
    "reconnect_alert_cooldown_minutes": 30
  }
}